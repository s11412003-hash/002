ll; witchHealUsed = true; } } function witchPoison(){ if(witchPoisonUsed){ alert(&quot;&#27602;&#34277;&#24050;&#20351;&#29992;&quot;); return; } const targetId = parseInt( document.getElementById(&quot;targetSelect&quot;).value ); const target = players.find(p=&gt;p.id===targetId); target.alive = false; witchPoisonUsed = true; addLog(</span><span class="c0">&#9760;&#65039; &#22899;&#24043;&#27602;&#27578; ${target.name}</span><span>); renderPlayers(); checkVictory(); } function votePlayer(){ const targetId = parseInt( document.getElementById(&quot;targetSelect&quot;).value ); const target = players.find(p=&gt;p.id===targetId); target.alive = false; addLog(</span><span class="c0">&#128499;&#65039; ${target.name} &#34987;&#20844;&#25237;&#20986;&#23616;</span><span>); renderPlayers(); checkVictory(); } function checkVictory(){ const alive = players.filter(p=&gt;p.alive); const wolves = alive.filter(p=&gt;p.side===&quot;&#29436;&#20154;&quot;); const good = alive.filter(p=&gt;p.side===&quot;&#22909;&#20154;&quot;); if(wolves.length===0){ addLog(</span><span class="c0">&nbsp;</span><span>&lt;h2 class=&quot;good&quot;&gt; &#127881; &#22909;&#20154;&#21213;&#21033;&#65281; &lt;/h2&gt; </span><span class="c0">); </span><span>alert(&quot;&#22909;&#20154;&#21213;&#21033;&#65281;&quot;); } if(wolves.length &gt;= good.length){ addLog(</span><span class="c0">&nbsp;</span><span>&lt;h2 class=&quot;wolf&quot;&gt; &#128058; &#29436;&#20154;&#21213;&#21033;&#65281; &lt;/h2&gt; </span><span class="c0">); </span><span class="c3">alert(&quot;&#29436;&#20154;&#21213;&#21033;&#65281;&quot;); } } &lt;/script&gt; &lt;/body&gt; &lt;/html&gt; </span></p></body></html>
